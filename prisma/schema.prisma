generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String? // নতুন যোগ করা হয়েছে
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      String?  @default("user")

  // Relations
  chatMessages ChatMessage[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  sessionId String
  role      String // 'user' or 'assistant'
  content   String
  vector    Float[] // Vector embedding for MongoDB Vector Search
  timestamp DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("chat_messages")
}

model BlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  content     String // এটি HTML কন্টেন্ট স্টোর করবে
  cover_image String
  category    String   @default("Technical")
  excerpt     String? // ছোট সামারি (কার্ডে দেখানোর জন্য)
  tags        String[] @default([])
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Blog Category Model for proper category management
model BlogCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contact Form Submission Model
model ContactSubmission {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  company   String
  email     String
  service   String
  details   String
  status    String   @default("pending") // pending, replied, resolved, archived
  response  String? // Admin's response/notes about this submission
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Newsletter Subscription Model
model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}

model Review {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  designation      String
  company          String
  testimonialTitle String
  imageUrl         String
  videoUrl         String?
  complement       String // বড় টেক্সটের জন্য @db.Text ব্যবহার করা ভালো
  timeSaved        String?
  efficiencyGain   String?
  rating           Int      @default(5)
  status           String   @default("approved") // pending, approved, rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

type CaseContent {
  title           String
  context         String
  problem         String
  solution        String
  myApproach      String? // The Strategy / Story
  failedAttempts  String? // Challenges & what didn't work initially
  result          String
  metric          String // e.g., "70% Cost Reduction"
  testimonial     String?
  testimonialRole String? // e.g., "CEO", "Operations Manager"
}

model CaseStudy {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  category String
  techTags String[]

  // Client & Project Metadata
  clientName      String?
  clientLocation  String? // e.g., "USA", "UK", "Bangladesh"
  industry        String? // e.g., "E-commerce", "Healthcare"
  projectDuration String? // e.g., "3 Weeks", "2 Months"

  // Visuals & Media
  heroImage         String?
  videoReviewUrl    String? // Client Testimonial Video (YouTube/Loom)
  dashboardVideoUrl String? // Solution Demo Video
  n8nDiagramUrl     String? // Workflow Diagram Image
  gallery           String[] // [image1_url, image2_url, ...]

  // Comparative Stats (ROI Calculator support)
  beforeMetricValue Int? // e.g., 40 (hours)
  afterMetricValue  Int? // e.g., 2 (hours)
  metricUnit        String? // e.g., "hrs/week", "USD", "%"

  // Multi-language Content (The Story)
  en CaseContent
  bn CaseContent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // General Site Settings
  siteName        String  @default("Driplare")
  siteTitle       String  @default("AI Agent and Automation")
  footerCopyright String  @default("© 2026 All Rights Reserved")
  logoUrl         String?
  faviconUrl      String?

  // Social Media Links & Permissions
  youtubeUrl    String?
  linkedinUrl   String?
  facebookUrl   String?
  twitterUrl    String?
  instagramUrl  String?
  showYouTube   Boolean @default(false)
  showTwitter   Boolean @default(false)
  showInstagram Boolean @default(false)
  showFacebook  Boolean @default(true)
  showLinkedin  Boolean @default(true)

  // SEO & Tracking
  googleAnalyticsId String?
  metaDescription   String?

  // System Control
  maintenanceMode Boolean @default(false)

  // API Config (Non-sensitive only)
  cloudinaryFolder String @default("portfolio")
  resendFromEmail  String @default("onboarding@resend.dev")

  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Agent Content Type for Multi-language Support
type AgentContent {
  name            String
  description     String
  fullDescription String
  features        String[]
}

model Agent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  slug       String   @unique
  price      Float
  rating     Float    @default(5.0)
  totalSales Int      @default(0)
  category   String
  mainImage  String
  gallery    String[]
  videoUrl   String?
  techStack  String[]
  difficulty String   @default("Easy")
  setupTime  String?
  status     String   @default("active")

  // Multi-language Content (like CaseStudy)
  en AgentContent
  bn AgentContent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agents")
}

