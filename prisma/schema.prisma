// Add this to your existing schema.prisma file

model Lead {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String
  whatsapp     String
  businessType String?
  platform     String // messenger, whatsapp, both
  requirements String?

  // Agent info
  agentSlug String
  agentName String

  // Tracking
  source String // "product-page", "marketplace", "hero-cta"
  status String   @default("new") // new, contacted, qualified, proposal-sent, paid, completed, closed-lost
  notes  String[] // Array of notes

  // Timestamps
  createdAt       DateTime  @default(now())
  lastContactedAt DateTime?
  qualifiedAt     DateTime?
  paidAt          DateTime?
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([agentSlug])
  @@index([createdAt])
  @@map("leads")
}

